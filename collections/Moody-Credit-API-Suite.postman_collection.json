{
  "info": {
    "name": "Moody-Credit-API-Suite",
    "_postman_id": "moody-credit-api-suite-v1",
    "description": "Portfolio API test suite simulating credit account workflows. Built by Farhod Elbekov using reqres.in as mock backend. Covers CRUD operations, authentication, chaining, negative testing, and assertions — aligned to QA best practices for regulated financial environments.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://reqres.in",
      "type": "string"
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.collectionVariables.set('timestamp', new Date().toISOString());",
          "console.log('Collection pre-request fired at: ' + pm.collectionVariables.get('timestamp'));"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Phase 1 - Authentication",
      "item": [
        {
          "name": "POST Login - Valid Credentials",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response time under 2000ms', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);",
                  "});",
                  "",
                  "pm.test('Token is present in response', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('token');",
                  "    pm.expect(jsonData.token).to.be.a('string').and.not.empty;",
                  "});",
                  "",
                  "// Chain: save token for use in other requests",
                  "var jsonData = pm.response.json();",
                  "if (jsonData.token) {",
                  "    pm.environment.set('auth_token', jsonData.token);",
                  "    console.log('Token saved: ' + jsonData.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"eve.holt@reqres.in\",\n    \"password\": \"cityslicka\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/login",
              "host": ["{{base_url}}"],
              "path": ["api", "login"]
            },
            "description": "Authenticate and capture token. Token is saved to environment variable 'auth_token' for use in subsequent requests."
          }
        },
        {
          "name": "POST Login - Invalid Password (Negative)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 400 for invalid credentials', function () {",
                  "    pm.response.to.have.status(400);",
                  "});",
                  "",
                  "pm.test('Error message is present', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('error');",
                  "    pm.expect(jsonData.error).to.be.a('string').and.not.empty;",
                  "});",
                  "",
                  "pm.test('No token returned on failed login', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.not.have.property('token');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"eve.holt@reqres.in\",\n    \"password\": \"wrongpassword\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/login",
              "host": ["{{base_url}}"],
              "path": ["api", "login"]
            },
            "description": "Negative test: invalid password should return 400 with error message and no token."
          }
        },
        {
          "name": "POST Login - Missing Password (Negative)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 400 for missing password', function () {",
                  "    pm.response.to.have.status(400);",
                  "});",
                  "",
                  "pm.test('Error message mentions missing password', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('error');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"eve.holt@reqres.in\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/login",
              "host": ["{{base_url}}"],
              "path": ["api", "login"]
            },
            "description": "Negative test: missing required field 'password' should return 400."
          }
        }
      ]
    },
    {
      "name": "Phase 2 - GET Accounts (Read)",
      "item": [
        {
          "name": "GET All Users - Page 1",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response time under 2000ms', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);",
                  "});",
                  "",
                  "pm.test('Response has data array', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('data');",
                  "    pm.expect(jsonData.data).to.be.an('array').and.not.empty;",
                  "});",
                  "",
                  "pm.test('Pagination fields present', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('page');",
                  "    pm.expect(jsonData).to.have.property('total');",
                  "    pm.expect(jsonData).to.have.property('total_pages');",
                  "});",
                  "",
                  "pm.test('Each user has required fields', function () {",
                  "    var jsonData = pm.response.json();",
                  "    jsonData.data.forEach(function(user) {",
                  "        pm.expect(user).to.have.property('id');",
                  "        pm.expect(user).to.have.property('email');",
                  "        pm.expect(user).to.have.property('first_name');",
                  "        pm.expect(user).to.have.property('last_name');",
                  "    });",
                  "});",
                  "",
                  "// Chain: save first user id",
                  "var jsonData = pm.response.json();",
                  "if (jsonData.data && jsonData.data.length > 0) {",
                  "    pm.environment.set('user_id', jsonData.data[0].id);",
                  "    console.log('Saved user_id: ' + jsonData.data[0].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/users?page=1",
              "host": ["{{base_url}}"],
              "path": ["api", "users"],
              "query": [{ "key": "page", "value": "1" }]
            },
            "description": "Get paginated list of users. Validates structure, pagination, and required fields. Saves first user ID for chaining."
          }
        },
        {
          "name": "GET Single User by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('User data is present', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('data');",
                  "});",
                  "",
                  "pm.test('User has all required fields', function () {",
                  "    var user = pm.response.json().data;",
                  "    pm.expect(user).to.have.property('id');",
                  "    pm.expect(user).to.have.property('email');",
                  "    pm.expect(user).to.have.property('first_name');",
                  "    pm.expect(user).to.have.property('last_name');",
                  "    pm.expect(user).to.have.property('avatar');",
                  "});",
                  "",
                  "pm.test('User ID matches requested ID', function () {",
                  "    var user = pm.response.json().data;",
                  "    pm.expect(user.id).to.eql(2);",
                  "});",
                  "",
                  "pm.test('Email format is valid', function () {",
                  "    var user = pm.response.json().data;",
                  "    pm.expect(user.email).to.match(/^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/users/2",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "2"]
            },
            "description": "Get a single user by ID. Validates all required fields and email format."
          }
        },
        {
          "name": "GET User - Not Found (Negative)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 404 for non-existent user', function () {",
                  "    pm.response.to.have.status(404);",
                  "});",
                  "",
                  "pm.test('Response body is empty object', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.be.an('object');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/users/9999",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "9999"]
            },
            "description": "Negative test: request a user ID that does not exist. Expects 404."
          }
        }
      ]
    },
    {
      "name": "Phase 3 - POST Account (Create)",
      "item": [
        {
          "name": "POST Create New User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201 Created', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response time under 2000ms', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);",
                  "});",
                  "",
                  "pm.test('Created user has an ID', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('id');",
                  "    pm.expect(jsonData.id).to.not.be.empty;",
                  "});",
                  "",
                  "pm.test('Created user has createdAt timestamp', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('createdAt');",
                  "});",
                  "",
                  "pm.test('Name matches request payload', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.name).to.eql('Farhod Elbekov');",
                  "});",
                  "",
                  "pm.test('Job matches request payload', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.job).to.eql('Senior QA Engineer');",
                  "});",
                  "",
                  "// Chain: save new user id for PUT/PATCH/DELETE",
                  "var jsonData = pm.response.json();",
                  "pm.environment.set('new_user_id', jsonData.id);",
                  "console.log('New user created with id: ' + jsonData.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Farhod Elbekov\",\n    \"job\": \"Senior QA Engineer\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/users",
              "host": ["{{base_url}}"],
              "path": ["api", "users"]
            },
            "description": "Create a new user. Validates 201 status, ID generation, timestamp, and payload echo. Saves ID for chaining."
          }
        }
      ]
    },
    {
      "name": "Phase 4 - PUT and PATCH (Update)",
      "item": [
        {
          "name": "PUT Update User - Full Replace",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('updatedAt timestamp is present', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('updatedAt');",
                  "});",
                  "",
                  "pm.test('Name updated correctly', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.name).to.eql('Farhod Elbekov');",
                  "});",
                  "",
                  "pm.test('Job updated correctly', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.job).to.eql('Lead QA Automation Engineer');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Farhod Elbekov\",\n    \"job\": \"Lead QA Automation Engineer\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/users/2",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "2"]
            },
            "description": "Full update (replace) of a user record. Validates 200, updatedAt, and field values."
          }
        },
        {
          "name": "PATCH Update User - Partial (Job Only)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('updatedAt timestamp is present', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('updatedAt');",
                  "});",
                  "",
                  "pm.test('Job field was updated', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.job).to.eql('AI QA Engineer');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"job\": \"AI QA Engineer\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/users/2",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "2"]
            },
            "description": "Partial update — only job field. Validates 200, updatedAt, and that job was changed."
          }
        }
      ]
    },
    {
      "name": "Phase 5 - DELETE Account",
      "item": [
        {
          "name": "DELETE User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 204 No Content', function () {",
                  "    pm.response.to.have.status(204);",
                  "});",
                  "",
                  "pm.test('Response body is empty', function () {",
                  "    pm.expect(pm.response.text()).to.be.empty;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/users/2",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "2"]
            },
            "description": "Delete a user. Expects 204 No Content with empty response body."
          }
        }
      ]
    },
    {
      "name": "Phase 6 - Delayed Response (Performance)",
      "item": [
        {
          "name": "GET Delayed Response - Performance Check",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response time is within acceptable SLA (5000ms)', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(5000);",
                  "});",
                  "",
                  "pm.test('Data array is returned despite delay', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('data');",
                  "    pm.expect(jsonData.data).to.be.an('array');",
                  "});",
                  "",
                  "console.log('Actual response time: ' + pm.response.responseTime + 'ms');"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/users?delay=3",
              "host": ["{{base_url}}"],
              "path": ["api", "users"],
              "query": [{ "key": "delay", "value": "3" }]
            },
            "description": "Simulates a slow API response (3 second delay). Tests SLA threshold and validates data integrity under delay — relevant for compliance reporting systems."
          }
        }
      ]
    }
  ]
}
